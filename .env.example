# ─────────────────────────────────────────────────────────────────────────
# Student Learning Analytics — environment configuration
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# All values below are safe local defaults except secrets.
# ─────────────────────────────────────────────────────────────────────────

# --- Simulation (Phase 1) ---
SLA_SEED=42
SLA_N_STUDENTS=50
SLA_SIM_WEEKS=12
SLA_DATA_DIR=data

# --- PostgreSQL (Phase 2) ---
POSTGRES_USER=sla
POSTGRES_PASSWORD=sla_password
POSTGRES_DB=sla
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host port mapping (change if 5432 is already in use on your machine).
POSTGRES_HOST_PORT=5432
# SQLAlchemy URL is derived from the parts above by sla.config.

# --- Airflow (Phase 2) ---
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change-me
# Admin user created by airflow-init; also used by the API to call the REST API.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Airflow stable REST API base (used by /pipeline/* endpoints + n8n workflows).
AIRFLOW_API_URL=http://airflow-webserver:8080/api/v1

# --- ChromaDB (Phase 4) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=pedagogy

# --- LLM / RAG (Phase 4) ---
# Leave OPENAI_API_KEY empty to run the deterministic offline mock provider.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- API + dashboard (Phase 4/5) ---
API_HOST=0.0.0.0
API_PORT=8001
# Host port mapping for the API (change if 8001 is taken).
API_HOST_PORT=8001
API_BASE_URL=http://api:8001
# Host port mapping for the Streamlit dashboard.
STREAMLIT_HOST_PORT=8501
# Comma-separated origins allowed by CORS (Streamlit + Next.js frontend)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# --- Next.js dashboard (Phase 5b) ---
# Browser-side URL of the API (must be reachable from the user's browser, so the
# host-published port — NOT the docker-internal `api:8001`).
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXTJS_HOST_PORT=3000

# --- n8n automation (Phase 6) ---
N8N_HOST_PORT=5678
# Local dev: skip the owner login screen entirely (no email/password).
N8N_USER_MANAGEMENT_DISABLED=true
# Legacy basic-auth (ignored when user management is disabled; kept for reference).
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin
# Public base URL n8n uses to build webhook URLs.
WEBHOOK_URL=http://localhost:5678

# --- Notifications for n8n workflows (Phase 6) ---
# SMTP host/port/user/pass go in the n8n SMTP *credential* (UI), not here.
# Local default: the bundled Mailhog service (host `mailhog`, port 1025, no auth).
# Mailhog web inbox: http://localhost:8025
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
# From address used by the email nodes (exposed to n8n as $env.SMTP_FROM).
SMTP_FROM=learning-analytics@example.com
# Incoming Slack webhook URL (https://hooks.slack.com/services/...).
SLACK_WEBHOOK_URL=
